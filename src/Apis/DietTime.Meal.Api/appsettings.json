{
  "AllowedHosts": "*",
  "Jwt": { "Issuer": "", "Audience": "", "Key": "", "AccessTokenMinutes": 15, "RefreshTokenDays": 30 },
  "Storage": { "ServiceUrl": "", "PublicBaseUrl": "", "BucketName": "", "AccessKey": "", "SecretKey": "", "Region": "auto", "MaxUploadSizeBytes": 10485760 },
  "Cors": { "AllowedOrigins": [] },
